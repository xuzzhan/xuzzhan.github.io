---
layout: none
permalink: /api/posts.json
---
[
  {% for post in site.posts %}
  {
    "date": "{{ post.date | date: '%Y-%m-%d' }}",
    "title": {{ post.title | jsonify }},
    "url": "{{ post.url | relative_url }}",
    "words": {{ post.content | strip_html | number_of_words }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]